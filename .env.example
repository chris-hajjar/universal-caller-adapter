# =============================================================================
# Agentic Platform POC — Environment Variables
# =============================================================================
# Copy this to .env and fill in your values.

# ---------------------------------------------------------------------------
# Okta (Identity)
# ---------------------------------------------------------------------------
# Leave blank for local dev mode (JWT verification skipped, hardcoded manifests)
OKTA_DOMAIN=                      # e.g. dev-12345.okta.com
OKTA_AUDIENCE=api://default
OKTA_CLIENT_ID=
OKTA_API_TOKEN=                   # SSWS token for admin API (manifest read/write)

# Owner email — gateway skips permission checks for this user
OWNER_EMAIL=chris@company.com

# ---------------------------------------------------------------------------
# MariaDB (Railway)
# ---------------------------------------------------------------------------
MARIADB_HOST=
MARIADB_PORT=3306
MARIADB_USER=root
MARIADB_PASSWORD=
MARIADB_DATABASE=agentic_platform

# ---------------------------------------------------------------------------
# Supabase (pgvector)
# ---------------------------------------------------------------------------
SUPABASE_URL=                     # e.g. https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=             # service_role key (not anon key)

# ---------------------------------------------------------------------------
# OpenAI (Embeddings)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ---------------------------------------------------------------------------
# MCP Server URLs (backend servers the gateway proxies to)
# ---------------------------------------------------------------------------
MCP_MARIADB_URL=http://localhost:8001
MCP_MEMORY_URL=http://localhost:8002
MCP_SLACK_URL=http://localhost:8003
MCP_REPORTS_URL=http://localhost:8004

# ---------------------------------------------------------------------------
# Slack Bot
# ---------------------------------------------------------------------------
SLACK_BOT_TOKEN=                  # xoxb-...
SLACK_APP_TOKEN=                  # xapp-... (for socket mode)

# Map Slack user IDs to gateway tokens
# Format: SLACK_USER_MAP=U01ABC:token1,U02DEF:token2
SLACK_USER_MAP=

# ---------------------------------------------------------------------------
# Gateway
# ---------------------------------------------------------------------------
GATEWAY_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:8501,http://localhost:3000
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Dev tokens (used in dev mode when Okta is not configured)
# ---------------------------------------------------------------------------
OWNER_TOKEN=chris@company.com
USER_A_TOKEN=user_a@company.com
USER_B_TOKEN=user_b@company.com
